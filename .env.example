# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your own Telegram numeric user ID (the bot only responds to this user).
# Get it from @userinfobot
TELEGRAM_OWNER_ID=

# Postgres connection string, e.g. postgres://user:pass@host:5432/dbname
DATABASE_URL=

# Full contents of the Google service account JSON key, as a single line.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Which calendar to read. Use "primary" for your main calendar, or a
# specific calendar's ID (Calendar settings -> Integrate calendar -> Calendar ID).
GOOGLE_CALENDAR_ID=primary

# Language for voice message recognition (BCP-47). Requires the Speech-to-Text
# API enabled on the same Google Cloud project as GOOGLE_SERVICE_ACCOUNT_JSON.
SPEECH_LANGUAGE_CODE=uz-UZ

# Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# IANA timezone name, no DST in Tashkent so this stays fixed at UTC+5.
TIMEZONE=Asia/Tashkent

# Daily summary delivery time, 24h HH:MM, in the TIMEZONE above.
SUMMARY_TIME=08:00

# How many minutes before a calendar event to send a reminder.
REMINDER_LEAD_MINUTES=30

# How often (minutes) to check the calendar for upcoming events to remind about.
REMINDER_CHECK_INTERVAL_MINUTES=15

# HTTP port for the Mini App server. Railway sets PORT itself; safe to leave
# the default for local dev.
PORT=8080

# Public HTTPS URL of the Mini App (Railway domain or a tunnel). Leave empty
# to run without the Telegram menu button / Mini App.
WEBAPP_URL=

# Billz secret_token (Ключи интеграции -> your key -> Роль -> права в разделах
# "Продажи"/"Отчёты"). Read-only: the bot only ever calls report endpoints.
# Leave empty to run without the business section on the dashboard.
BILLZ_SECRET_TOKEN=
